# Prospection - Dokploy stack environment template
# Secrets injected via Dokploy UI (Project > Environment). DO NOT commit real values.

# === Deploy environment selector ===
# prod = stack prospection-prod (Host prospection.app.veridian.site)
# green = stack prospection-green (Host prospection.green.app.veridian.site)
# Used by container name, Traefik labels, and any per-env override.
DEPLOY_ENV=prod
TRAEFIK_HOST=prospection.app.veridian.site

# === Auth.js v5 ===
AUTH_SECRET=
NEXTAUTH_URL=https://prospection.app.veridian.site

# === URLs publiques (12-factor, cf. 07-inter-app-communication.md) ===
APP_URL=https://prospection.app.veridian.site
NEXT_PUBLIC_SITE_URL=https://prospection.app.veridian.site
NEXT_PUBLIC_HUB_URL=https://app.veridian.site
NEXT_PUBLIC_SUPABASE_URL=https://api.app.veridian.site

# === Database (Postgres dedie prospection) ===
# Format: postgresql://USER:PASSWORD@HOST:5432/DB?connection_limit=10
# Le container DB tourne dans un compose separe (code-prospection-saas-db-1)
DATABASE_URL=

# === Supabase (Hub backend, appele server-side) ===
# TODO: migrer SUPABASE_URL vers https://api.app.veridian.site (URL publique, cf. 07-inter-app-communication.md)
# Le nom interne du container Kong casse a chaque rename de stack Dokploy.
SUPABASE_URL=http://compose-parse-digital-alarm-974mhw-kong-1:8000
ANON_KEY=
SERVICE_ROLE_KEY=

# === Cross-tenant API (Hub -> Prospection provisioning) ===
TENANT_API_SECRET=
