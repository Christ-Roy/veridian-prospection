# Prospection — Environment Variables
# Copy to .env.local and fill in real values

# Database (Prisma + PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/prospection

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://api.app.veridian.site
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Hub integration
NEXT_PUBLIC_HUB_URL=https://app.veridian.site
NEXT_PUBLIC_SITE_URL=https://prospection.app.veridian.site

# Auth
AUTH_MODE=supabase
TENANT_API_SECRET=your-tenant-secret
ADMIN_EMAILS=robert.brunon@veridian.site

# Trial
NEXT_PUBLIC_TRIAL_DAYS=7

# Stripe (optional — for checkout flow)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
