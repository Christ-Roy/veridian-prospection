# ============================================================================
# Veridian Prospection — Variables d'environnement
# ============================================================================
#
# Convention :
#   [REQUIRED]   — l'app crash sans, à poser sur tout environnement
#   [OPTIONAL]   — feature dégradée si absente (fallback silencieux)
#   [BUILD-TIME] — injectée à la build Docker, lue runtime
#   [DEV-ONLY]   — utilisée seulement en local/dev, jamais en prod
#   [LEGACY]     — fenêtre de migration, à retirer après date prévue
#
# Source de vérité runtime prod : Dokploy ENV (interface UI) — voir
# veridian-infra/todo/ pour le ticket backup secrets.
#
# Copy to .env.local et remplis les valeurs réelles pour le dev local.
# ============================================================================


# ──────────────────────────────────────────────────────────────────────────────
# § 1. Database
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL via Prisma. Format : postgresql://user:pass@host:port/db
DATABASE_URL=postgresql://postgres:password@localhost:5432/prospection


# ──────────────────────────────────────────────────────────────────────────────
# § 2. Auth (Auth.js v5 — flux principal)
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Secret JWT Auth.js. openssl rand -base64 32
AUTH_SECRET=your-auth-secret-min-32-chars

# [REQUIRED] URL absolue de l'app (cookie domain, callback OAuth)
NEXTAUTH_URL=http://localhost:3000

# [LEGACY] Alias historique d'AUTH_SECRET — lu uniquement par
# src/app/api/auth/token/route.ts comme fallback. À fusionner avec AUTH_SECRET
# quand on aura migré le code.
NEXTAUTH_SECRET=

# [OPTIONAL] OAuth Google (signup/login via Google). Si absent, bouton non
# affiché. Credentials à créer sur console.cloud.google.com.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=


# ──────────────────────────────────────────────────────────────────────────────
# § 3. Supabase Auth (legacy, en cours de retrait)
# ──────────────────────────────────────────────────────────────────────────────
# La majorité de l'auth est désormais sur Auth.js v5 (cf §2). Ces vars restent
# pour quelques flows résiduels (invitations email via Supabase SMTP, lookup
# legacy). À retirer post-audit dette technique 2026-Q3.

# [OPTIONAL] URL projet Supabase (legacy)
NEXT_PUBLIC_SUPABASE_URL=https://api.app.veridian.site
SUPABASE_URL=https://api.app.veridian.site

# [OPTIONAL] Clés Supabase (legacy)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# [OPTIONAL] Flag : "1" si SMTP Supabase configuré (sinon fallback magic link
# direct). Lu par src/lib/invitations.ts.
SUPABASE_SMTP_CONFIGURED=0


# ──────────────────────────────────────────────────────────────────────────────
# § 4. Intégration Hub Veridian (contrat HMAC §6.1)
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] URLs publiques de l'app + Hub
NEXT_PUBLIC_HUB_URL=https://app.veridian.site
NEXT_PUBLIC_SITE_URL=https://prospection.app.veridian.site

# [REQUIRED] Secret partagé Hub ↔ Prospection (HMAC signature). 64 chars hex.
# Identique côté Hub (PROSPECTION_HUB_API_SECRET) et Prospection (HUB_API_SECRET).
HUB_API_SECRET=your-hub-api-secret-64-chars-hex

# [LEGACY] Alias historique d'HUB_API_SECRET. Migration §1 phase HMAC standard
# (cf todo/done/2026-05-19-hub-contract-phase1.md). À retirer après fenêtre 30j.
TENANT_API_SECRET=your-tenant-secret

# [REQUIRED] URL Hub pour les webhooks app → Hub (tenant.suspended, etc.)
HUB_API_URL=https://app.veridian.site

# [REQUIRED] Bearer token Hub pour signer les webhooks sortants (contrat §6.3).
# Côté Hub ce même token s'appelle PROSPECTION_WEBHOOK_TOKEN (token attribué
# à Prospection). Lu par src/lib/hub/webhooks.ts:43.
HUB_WEBHOOK_TOKEN=your-hub-webhook-token

# [DEV-ONLY] Si "1", désactive l'émission de webhooks (utile en local + tests
# unit). Lu par src/lib/hub/webhooks.ts.
HUB_WEBHOOK_DISABLE=1

# [LEGACY] Fenêtre 30j post-migration HMAC standard (2026-05-20). Quand le Hub
# n'émet plus de Bearer ni HMAC legacy_email_ts, poser ACCEPT_*=0 pour
# durcir. Cf todo/2026-05-19-hub-contract-phase1-suite.md.
ACCEPT_LEGACY_BEARER=1
ACCEPT_LEGACY_HMAC=1


# ──────────────────────────────────────────────────────────────────────────────
# § 5. Plans + Trial
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Nombre de jours de trial. Public car affiché dans l'UI.
NEXT_PUBLIC_TRIAL_DAYS=7

# [OPTIONAL] Overrides custom des caps leads par plan. Si absents, défauts
# hardcodés dans src/lib/queries/lead-quota.ts s'appliquent.
# Note : source de vérité pricing = src/lib/billing/plans.ts (plan-as-code).
# Ces overrides sont prévus pour des deals enterprise hors grille.
PLAN_LIMIT_FREEMIUM=
PLAN_LIMIT_STARTER=
PLAN_LIMIT_PRO=
PLAN_LIMIT_ENTERPRISE=


# ──────────────────────────────────────────────────────────────────────────────
# § 6. Stripe (checkout legacy — migration vers Hub centralisé en cours)
# ──────────────────────────────────────────────────────────────────────────────
# Le checkout passe par le Hub désormais. Ces vars restent pour le flow legacy
# src/app/api/checkout/route.ts (à virer après confirmation que plus aucun
# tenant ne l'utilise).

# [LEGACY] Clés Stripe pour checkout direct (à virer)
STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_SECRET_KEY_PREPROD=sk_test_...

# [LEGACY] Price IDs Stripe pour les plans legacy "geo" et "full"
STRIPE_PRICE_GEO=price_...
STRIPE_PRICE_FULL=price_...


# ──────────────────────────────────────────────────────────────────────────────
# § 7. Téléphonie SIP (Telnyx + FreeSwitch)
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Telnyx Voice API (click-to-call, transcription)
# Si absent : feature téléphonie désactivée dans l'UI.
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_CALL_CONTROL_APP_ID=
TELNYX_CREDENTIAL_ID=
TELNYX_PHONE_NUMBER=

# [OPTIONAL] FreeSwitch ESL (Event Socket Layer) — softphone WebRTC
# Si absent : pas de softphone dans l'UI.
FS_ESL_HOST=
FS_ESL_PORT=8021
FS_ESL_PASSWORD=


# ──────────────────────────────────────────────────────────────────────────────
# § 8. IA — Summarisation d'appels (ZAI)
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] ZAI (provider IA) pour résumés d'appels téléphoniques
# Si absent : feature "Résumé IA" désactivée dans l'UI.
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai


# ──────────────────────────────────────────────────────────────────────────────
# § 9. Web Push Notifications (VAPID)
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Web Push pour notifications navigateur. Générer avec :
#   npx web-push generate-vapid-keys
# Si absent : pas de notif push dans l'UI.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:robert.brunon@veridian.site


# ──────────────────────────────────────────────────────────────────────────────
# § 10. Cron jobs (vérification followups, etc.)
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED EN PROD] Secret d'auth pour les endpoints /api/cron/*. Le cron OVH
# envoie ce secret dans le header Authorization: Bearer <secret>.
# Sans ce secret, les crons retournent 401 = aucun followup déclenché.
# openssl rand -hex 32
CRON_SECRET=your-cron-secret-hex-32


# ──────────────────────────────────────────────────────────────────────────────
# § 11. Build-time / Observabilité (auto-injectées par CI, ne pas poser à la main)
# ──────────────────────────────────────────────────────────────────────────────

# [BUILD-TIME] SHA Git du build. Injecté par GitHub Actions dans le Dockerfile.
GIT_SHA=

# [BUILD-TIME] Version sémantique de l'app. Affichée dans /api/status.
NEXT_PUBLIC_APP_VERSION=0.2.0
NEXT_PUBLIC_COMMIT_SHA=
