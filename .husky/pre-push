#!/usr/bin/env sh
# Standard CI Veridian — pre-push hook
# Refuse le push si :
#   1. Fichier critique modifié sans test correspondant
#   2. infra/docker-compose.yml désync avec base + prod (édition manuelle interdite)
# JAMAIS --no-verify (Constitution CI §3).

set -e

BASE_REF="${BASE_REF:-origin/$(git rev-parse --abbrev-ref HEAD)}"
if ! git rev-parse --verify --quiet "$BASE_REF" >/dev/null 2>&1; then
  BASE_REF="origin/main"
fi
export BASE_REF

# 1. Test mapping
if [ -x scripts/ci/check-test-mapping.sh ]; then
  scripts/ci/check-test-mapping.sh
fi

# 1bis. Route safety audit (try/catch/.catch sur request.json + requireAdmin guards)
# Mode BLOCKING depuis 2026-05-21 — toutes les routes en dette ont été fixées.
# Skip d'urgence : SKIP_ROUTE_SAFETY=1 git push (à NE JAMAIS faire en CI).
if [ -x scripts/ci/check-route-safety.sh ]; then
  scripts/ci/check-route-safety.sh
fi

# 1ter. Secrets detection (Stripe, GitHub, AWS, private keys, etc.)
# BLOCKING. Skip d'urgence : SKIP_SECRETS_CHECK=1
# Allowlist par ligne : `# pragma: allowlist secret` ou `// pragma: ...`
if [ -x scripts/ci/check-secrets.sh ]; then
  scripts/ci/check-secrets.sh
fi

# 1quater. CVE check sur prod deps (mirror du CI)
# BLOCKING si critical/high. Skip d'urgence : SKIP_DEPS_CVE=1
# Pertinent uniquement si package.json/package-lock.json modifié.
if [ -x scripts/ci/check-deps-cve.sh ]; then
  scripts/ci/check-deps-cve.sh
fi

# 1quinquies. Hygiène code : gros fichiers + console.log (warning)
# BLOCKING pour fichiers > 1MB. WARNING seulement sur console.log dans src/.
# Skip d'urgence : SKIP_HYGIENE=1
if [ -x scripts/ci/check-hygiene.sh ]; then
  scripts/ci/check-hygiene.sh
fi

# 1sexies. ENV sync : process.env.X dans src/ doit être déclaré dans
# .env.example OU compose. BLOCKING. Skip d'urgence : SKIP_ENV_SYNC=1
if [ -x scripts/ci/check-env-sync.sh ]; then
  scripts/ci/check-env-sync.sh
fi

# 2. Rappel régénération compose si base/prod modifié
# Note : check sémantique désactivé (formats varient entre versions compose CLI).
# Reste à implémenter un check basé sur yq normalisé.
# Capture sépare pour ne pas faire échouer le hook quand grep ne match rien (set -e).
INFRA_CHANGES=$(git diff --name-only "$BASE_REF"...HEAD 2>/dev/null | grep -E '^infra/docker-compose\.(base|prod)\.yml$' || true)
if [ -n "$INFRA_CHANGES" ]; then
  echo "ℹ️  Tu as modifié infra/docker-compose.{base,prod}.yml."
  echo "   Vérifie que infra/docker-compose.yml a été régénéré :"
  echo "     ./scripts/ci/render-compose.sh prod"
fi

exit 0
