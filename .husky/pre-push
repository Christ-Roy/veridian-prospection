#!/usr/bin/env sh
# Standard CI Veridian — pre-push hook
# Refuse le push si fichier critique modifié sans test correspondant.
# JAMAIS --no-verify (Constitution CI §3).

if [ -x scripts/ci/check-test-mapping.sh ]; then
  BASE_REF="${BASE_REF:-origin/$(git rev-parse --abbrev-ref HEAD)}"
  # Si la branche distante n'existe pas (premier push), compare contre origin/main
  if ! git rev-parse --verify --quiet "$BASE_REF" >/dev/null 2>&1; then
    BASE_REF="origin/main"
  fi
  export BASE_REF
  exec scripts/ci/check-test-mapping.sh
fi

echo "⚠ scripts/ci/check-test-mapping.sh absent ou non exécutable"
exit 0
