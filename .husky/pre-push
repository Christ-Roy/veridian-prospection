#!/usr/bin/env sh
# Standard CI Veridian — pre-push hook
# Refuse le push si :
#   1. Fichier critique modifié sans test correspondant
#   2. infra/docker-compose.yml désync avec base + prod (édition manuelle interdite)
# JAMAIS --no-verify (Constitution CI §3).

set -e

BASE_REF="${BASE_REF:-origin/$(git rev-parse --abbrev-ref HEAD)}"
if ! git rev-parse --verify --quiet "$BASE_REF" >/dev/null 2>&1; then
  BASE_REF="origin/main"
fi
export BASE_REF

# 1. Test mapping
if [ -x scripts/ci/check-test-mapping.sh ]; then
  scripts/ci/check-test-mapping.sh
fi

# 1bis. Route safety audit (try/catch/.catch sur request.json + requireAdmin guards)
# Mode BLOCKING depuis 2026-05-21 — toutes les routes en dette ont été fixées.
# Skip d'urgence : SKIP_ROUTE_SAFETY=1 git push (à NE JAMAIS faire en CI).
if [ -x scripts/ci/check-route-safety.sh ]; then
  scripts/ci/check-route-safety.sh
fi

# 1ter. Secrets detection (Stripe, GitHub, AWS, private keys, etc.)
# BLOCKING. Skip d'urgence : SKIP_SECRETS_CHECK=1
# Allowlist par ligne : `# pragma: allowlist secret` ou `// pragma: ...`
if [ -x scripts/ci/check-secrets.sh ]; then
  scripts/ci/check-secrets.sh
fi

# 1quater. CVE check sur prod deps (mirror du CI)
# BLOCKING si critical/high. Skip d'urgence : SKIP_DEPS_CVE=1
# Pertinent uniquement si package.json/package-lock.json modifié.
if [ -x scripts/ci/check-deps-cve.sh ]; then
  scripts/ci/check-deps-cve.sh
fi

# 1quinquies. Hygiène code : gros fichiers + console.log (warning)
# BLOCKING pour fichiers > 1MB. WARNING seulement sur console.log dans src/.
# Skip d'urgence : SKIP_HYGIENE=1
if [ -x scripts/ci/check-hygiene.sh ]; then
  scripts/ci/check-hygiene.sh
fi

# 1sexies. ENV sync : process.env.X dans src/ doit être déclaré dans
# .env.example OU compose. BLOCKING. Skip d'urgence : SKIP_ENV_SYNC=1
if [ -x scripts/ci/check-env-sync.sh ]; then
  scripts/ci/check-env-sync.sh
fi

# 1septies. Garde-fou « l'app boote » — check-ui-build.sh
#
# Les tests unitaires Vitest/jsdom montent les composants depuis le code
# SOURCE — ils ne voient jamais le `next build` réel. Un composant peut
# passer 100 % des tests unitaires et casser le build de prod. check-ui-
# build.sh lance `npm run build` et vérifie l'intégrité du .next/
# (manifests App Router, chunks référencés présents, routes critiques
# compilées). BLOCKING.
#
# Lancé UNIQUEMENT si le push touche du frontend (composants, pages,
# next.config.ts, globals.css, package.json) — un push purement backend
# ne rebuild pas l'UI pour rien (le build dure ~2-4 min).
#
# Skip d'urgence : SKIP_UI_BUILD=1 git push (à NE JAMAIS faire en CI).
# Fail-safe : script absent/non exécutable alors qu'un fichier frontend
# est modifié = push refusé (pas exit 0 silencieux).
UI_CHECK="scripts/ci/check-ui-build.sh"
FRONTEND_CHANGES=$(git diff --name-only "$BASE_REF"...HEAD 2>/dev/null \
  | grep -E '^src/(components|app)/|^next\.config\.ts$|^src/app/globals\.css$|^package\.json$' || true)

if [ -n "$FRONTEND_CHANGES" ]; then
  if [ "${SKIP_UI_BUILD:-0}" = "1" ]; then
    echo "⚠ check-ui-build.sh skipped via SKIP_UI_BUILD=1"
  else
    echo "── Husky pre-push : frontend modifié → check build UI ──"
    if [ ! -x "$UI_CHECK" ]; then
      echo "✗ $UI_CHECK introuvable ou non exécutable — push refusé."
      echo "  Run: chmod +x $UI_CHECK"
      exit 1
    fi
    if ! "$UI_CHECK"; then
      echo
      echo "✗ Push refusé : le build de l'app est cassé ou structurellement risqué."
      echo "  Une app qui ne boote pas = prod morte. Corrige avant de pousser."
      echo "  Skip d'urgence (à éviter) : SKIP_UI_BUILD=1 git push"
      exit 1
    fi
  fi
fi

# 1octies. Sabotage-test — un test qui n'observe rien d'utile DOIT mourir
# au sabotage léger de sa source. Le bug invitations 2026-05-23 (Supabase
# mort 5 jours en silence) a passé tous les filtres parce que le test
# mockait fetch — ce check le détecterait.
# BLOCKING. Skip d'urgence : SKIP_SABOTAGE_TEST=1 git push
# Fail-safe : script absent/non exécutable alors qu'on a des tests modifiés
# = push refusé (pas exit 0 silencieux).
SABOTAGE_CHECK="scripts/ci/check-sabotage-test.sh"
TEST_CHANGES=$(git diff --name-only "$BASE_REF"...HEAD 2>/dev/null | grep -E '\.test\.(ts|tsx)$' || true)
if [ -n "$TEST_CHANGES" ]; then
  if [ "${SKIP_SABOTAGE_TEST:-0}" = "1" ]; then
    echo "⚠ check-sabotage-test.sh skipped via SKIP_SABOTAGE_TEST=1"
  else
    if [ ! -x "$SABOTAGE_CHECK" ]; then
      echo "✗ $SABOTAGE_CHECK introuvable ou non exécutable — push refusé."
      echo "  Run: chmod +x $SABOTAGE_CHECK"
      exit 1
    fi
    if ! "$SABOTAGE_CHECK"; then
      echo
      echo "✗ Push refusé : au moins un test ne prouve pas qu'il détecte."
      echo "  Cf bug invitations 2026-05-23 (test vert sur Supabase mort)."
      echo "  Skip d'urgence (à éviter) : SKIP_SABOTAGE_TEST=1 git push"
      exit 1
    fi
  fi
fi

# 1nonies. Smoke contractuel cross-app — chaque endpoint Veridian appelé
# en runtime DOIT exister en staging. Anti-régression directe du bug
# invitations 2026-05-23 : l'URL /auth/v1/admin/users était littérale,
# Supabase mort, aucun test ne le détectait. Ce check curl HEAD chaque
# endpoint cross-app extrait du code et bloque sur 404.
# BLOCKING. Skip d'urgence : SKIP_CROSS_APP_CONTRACTS=1 git push
# Fail-safe : script absent alors qu'on a du code applicatif modifié
# = push refusé.
CROSSAPP_CHECK="scripts/ci/check-cross-app-contracts.sh"
APP_CODE_CHANGES=$(git diff --name-only "$BASE_REF"...HEAD 2>/dev/null \
  | grep -E '^src/(lib|app|components)/' | grep -v '\.test\.' || true)
if [ -n "$APP_CODE_CHANGES" ]; then
  if [ "${SKIP_CROSS_APP_CONTRACTS:-0}" = "1" ]; then
    echo "⚠ check-cross-app-contracts.sh skipped via SKIP_CROSS_APP_CONTRACTS=1"
  else
    if [ ! -x "$CROSSAPP_CHECK" ]; then
      echo "✗ $CROSSAPP_CHECK introuvable ou non exécutable — push refusé."
      echo "  Run: chmod +x $CROSSAPP_CHECK"
      exit 1
    fi
    if ! "$CROSSAPP_CHECK"; then
      echo
      echo "✗ Push refusé : un endpoint cross-app référencé est mort."
      echo "  Cf bug invitations 2026-05-23 (Supabase mort 5 jours)."
      echo "  Skip d'urgence (à éviter) : SKIP_CROSS_APP_CONTRACTS=1 git push"
      exit 1
    fi
  fi
fi

# 1decies. Drift Prisma — schema.prisma doit refléter la DB réelle.
# WARN ONLY en v1 — on observe avant de durcir (drifts connus :
# results, segment_catalog, before_enrich, staging_*).
# Le script lui-même ne renvoie jamais exit ≠ 0 sauf erreur technique,
# donc on capture pour ne PAS bloquer le push en v1.
# Skip d'urgence : SKIP_PRISMA_DRIFT=1 git push
DRIFT_CHECK="scripts/ci/check-prisma-drift.sh"
PRISMA_CHANGES=$(git diff --name-only "$BASE_REF"...HEAD 2>/dev/null \
  | grep -E '^prisma/(schema\.prisma|migrations/)' || true)
if [ -n "$PRISMA_CHANGES" ]; then
  if [ "${SKIP_PRISMA_DRIFT:-0}" = "1" ]; then
    echo "⚠ check-prisma-drift.sh skipped via SKIP_PRISMA_DRIFT=1"
  else
    if [ ! -x "$DRIFT_CHECK" ]; then
      echo "⚠ $DRIFT_CHECK introuvable — drift Prisma non vérifié (warn only)."
    else
      # WARN only en v1 — on ignore l'exit code pour ne PAS bloquer
      "$DRIFT_CHECK" || true
    fi
  fi
fi

# 1undecies. Garde-fou TS strict + ESLint — mirror CI quality gate.
#
# Évite le yo-yo CI : un test qui passe Vitest local (transpilé permissif
# via tsx) peut casser tsc --noEmit strict ou eslint --quiet de la CI.
# Incident 2026-05-23 : 3 push consécutifs pour 1 test livré (commits
# 01233a6, ba71dd9, 6450f55), tous TS/ESLint que le hook n'attrapait pas.
#
# BLOCKING. Coût ~15-30s sur warm cache npm.
# Skip d'urgence : SKIP_TYPECHECK_LINT=1
TC_LINT_CHECK="scripts/ci/check-typecheck-lint.sh"
SRC_OR_TEST_CHANGES=$(git diff --name-only "$BASE_REF"...HEAD 2>/dev/null \
  | grep -E '^(src|__tests__|e2e)/' || true)

if [ -n "$SRC_OR_TEST_CHANGES" ]; then
  if [ "${SKIP_TYPECHECK_LINT:-0}" = "1" ]; then
    echo "⚠ check-typecheck-lint.sh skipped via SKIP_TYPECHECK_LINT=1"
  else
    if [ ! -x "$TC_LINT_CHECK" ]; then
      echo "✗ $TC_LINT_CHECK introuvable et code/tests modifiés — push refusé"
      exit 1
    fi
    "$TC_LINT_CHECK"
  fi
fi

# 2. Rappel régénération compose si base/prod modifié
# Note : check sémantique désactivé (formats varient entre versions compose CLI).
# Reste à implémenter un check basé sur yq normalisé.
# Capture sépare pour ne pas faire échouer le hook quand grep ne match rien (set -e).
INFRA_CHANGES=$(git diff --name-only "$BASE_REF"...HEAD 2>/dev/null | grep -E '^infra/docker-compose\.(base|prod)\.yml$' || true)
if [ -n "$INFRA_CHANGES" ]; then
  echo "ℹ️  Tu as modifié infra/docker-compose.{base,prod}.yml."
  echo "   Vérifie que infra/docker-compose.yml a été régénéré :"
  echo "     ./scripts/ci/render-compose.sh prod"
fi

exit 0
