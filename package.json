{
  "name": "prospection-dashboard",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:integration": "vitest run e2e/integration/",
    "test:isolation": "vitest run e2e/integration/tenant-isolation.test.ts",
    "test:unit": "vitest run src/",
    "test:guard": "bash scripts/check-supabase-ratelimit.sh",
    "test:all": "npx tsc --noEmit && npx eslint src/ --quiet && vitest run src/ && bash scripts/check-supabase-ratelimit.sh",
    "db:fresh:siren": "bash scripts/db-fresh-siren.sh",
    "db:fresh:siren:seed": "SEED=1 bash scripts/db-fresh-siren.sh"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@telnyx/webrtc": "^2.25.25",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.575.0",
    "next": "^15.5.14",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.8",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.7.0",
    "sip.js": "^0.21.2",
    "sonner": "^2.0.7",
    "stripe": "^21.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "prisma": "^6.19.2",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
