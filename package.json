{
  "name": "prospection-dashboard",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "e2e:staging:full": "bash scripts/e2e/staging-full.sh",
    "test:integration": "vitest run e2e/integration/",
    "test:isolation": "vitest run e2e/integration/tenant-isolation.test.ts",
    "test:unit": "vitest run src/",
    "test:all": "npx tsc --noEmit && npx eslint src/ __tests__/ --quiet && vitest run src/ __tests__/",
    "db:fresh:siren": "bash scripts/db-fresh-siren.sh",
    "db:fresh:siren:seed": "SEED=1 bash scripts/db-fresh-siren.sh",
    "prepare": "husky",
    "setup-hooks": "husky"
  },
