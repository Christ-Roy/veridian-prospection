// Prisma schema — Prospection Dashboard (SIREN-centric SaaS)
// 2026-04-05: Radical refactor. `results`, `email_verification`, `phone_verification`,
// `pj_leads`, `ovh_monthly_destinations` are NO LONGER in the Prisma schema.
// They still exist in DB as legacy tables (filet de sécurité) but are not used.
//
// The source of truth is now `entreprises` (996K SIREN from open-data-hub v3.8).
// All metier tables (outreach, call_log, followups, claude_activity, outreach_emails,
// lead_segments) now reference `siren` instead of `domain`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENTREPRISES — SIREN-centric master table (source: open-data-hub v3.8)
// ============================================================================
//
// Convention for dashboard queries:
//   - Always filter `is_registrar = false`
//   - Always filter `NOT COALESCE(ca_suspect, false)` (activates composite indexes)
//   - Use `best_phone_e164` (not `best_phone`)
//   - Sort by `prospect_score DESC` (0-100)

model Entreprise {
  // --- Identité SIRENE ---
  siren               String    @id
  siretSiege          String?   @map("siret_siege")
  denomination        String?
  sigle               String?
  formeJuridique      String?   @map("forme_juridique")
  codeNaf             String?   @map("code_naf")
  nafLibelle          String?   @map("naf_libelle")
  categorieEntreprise String?   @map("categorie_entreprise")
  trancheEffectifs    String?   @map("tranche_effectifs")
  dateCreation        DateTime? @map("date_creation") @db.Date

  // --- Adresse ---
  adresse     String?
  codePostal  String? @map("code_postal")
  commune     String?
  departement String?
  codeCommune String? @map("code_commune")

  // --- Contact (version brute + normalisée) ---
  bestPhone       String? @map("best_phone")
  bestPhoneType   String? @map("best_phone_type")
  bestEmail       String? @map("best_email")
  socialLinkedin  String? @map("social_linkedin")
  socialFacebook  String? @map("social_facebook")
  socialInstagram String? @map("social_instagram")
  socialTwitter   String? @map("social_twitter")

  // Versions normalisées à utiliser par défaut
  bestPhoneE164       String? @map("best_phone_e164")
  bestEmailNormalized String? @map("best_email_normalized")
  bestEmailType       String? @map("best_email_type")
  webDomainNormalized String? @map("web_domain_normalized")

  // --- Dirigeant ---
  dirigeantNom     String? @map("dirigeant_nom")
  dirigeantPrenom  String? @map("dirigeant_prenom")
  dirigeantQualite String? @map("dirigeant_qualite")

  // --- Web ---
  webDomain             String?  @map("web_domain")
  webDomainsAll         Json?    @map("web_domains_all")
  webDomainCount        Int?     @map("web_domain_count") @db.SmallInt
  webCms                String?  @map("web_cms")
  webPlatform           String?  @map("web_platform")
  webTechScore          Int?     @map("web_tech_score") @db.SmallInt
  webObsolescenceScore  Int?     @map("web_obsolescence_score") @db.SmallInt
  webEclateScore        Int?     @map("web_eclate_score") @db.SmallInt
  webCopyrightYear      Int?     @map("web_copyright_year") @db.SmallInt
  webHasHttps           Boolean? @map("web_has_https")
  webHasResponsive      Boolean? @map("web_has_responsive")
  webHasEcommerce       Boolean? @map("web_has_ecommerce")
  webHasContactForm     Boolean? @map("web_has_contact_form")
  webHasMentionsLegales Boolean? @map("web_has_mentions_legales")
  webHasFlash           Boolean? @map("web_has_flash")
  webHasLayoutTables    Boolean? @map("web_has_layout_tables")
  webHasIePolyfills     Boolean? @map("web_has_ie_polyfills")
  webHasLoremIpsum      Boolean? @map("web_has_lorem_ipsum")
  webHasPhpsessid       Boolean? @map("web_has_phpsessid")
  webHasViewportNoScale Boolean? @map("web_has_viewport_no_scale")
  webHasMetaKeywords    Boolean? @map("web_has_meta_keywords")
  webHasMixedContent    Boolean? @map("web_has_mixed_content")
  webHasOldHtml         Boolean? @map("web_has_old_html")
  webHasOldImages       Boolean? @map("web_has_old_images")
  webHasModernImages    Boolean? @map("web_has_modern_images")
  webHasFavicon         Boolean? @map("web_has_favicon")
  webHasMinifiedAssets  Boolean? @map("web_has_minified_assets")
  webHasCompression     Boolean? @map("web_has_compression")
  webHasRecruitingPage  Boolean? @map("web_has_recruiting_page")
  webHasBlog            Boolean? @map("web_has_blog")
  webHasChatWidget      Boolean? @map("web_has_chat_widget")
  webHasBookingSystem   Boolean? @map("web_has_booking_system")
  webHasHoraires        Boolean? @map("web_has_horaires")
  webHasGoogleMaps      Boolean? @map("web_has_google_maps")

  // --- Finances ---
  chiffreAffaires BigInt?   @map("chiffre_affaires")
  resultatNet     BigInt?   @map("resultat_net")
  margeEbe        Float?    @map("marge_ebe")
  bilanDate       DateTime? @map("bilan_date") @db.Date

  // --- Certifications & labels ---
  estRge             Boolean? @map("est_rge")
  estQualiopi        Boolean? @map("est_qualiopi")
  qualiopiSpecialite String?  @map("qualiopi_specialite")
  estBio             Boolean? @map("est_bio")
  estEpv             Boolean? @map("est_epv")
  estFiness          Boolean? @map("est_finess")
  estEss             Boolean? @map("est_ess")
  estSurLbc          Boolean? @map("est_sur_lbc")
  estBni             Boolean? @map("est_bni")

  // --- Signaux business ---
  nbMarchesPublics      Int?      @map("nb_marches_publics")
  montantMarchesPublics BigInt?   @map("montant_marches_publics")
  decp2024Plus          Int?      @map("decp_2024_plus") @db.SmallInt
  decpLastDate          DateTime? @map("decp_last_date") @db.Date

  // --- Classification & scoring ---
  secteurFinal     String?   @map("secteur_final")
  domaineFinal     String?   @map("domaine_final")
  prospectTier     String?   @map("prospect_tier")
  prospectScore    Int?      @map("prospect_score") @db.SmallInt
  isProspectable   Boolean?  @map("is_prospectable")
  dataCompleteness Int?      @map("data_completeness") @db.SmallInt
  sourceCount      Int?      @map("source_count") @db.SmallInt
  signalCount      Int?      @map("signal_count") @db.SmallInt
  masterUpdatedAt  DateTime? @map("master_updated_at") @db.Timestamp

  // --- BODACC ---
  bodaccStatus       String? @map("bodacc_status")
  bodaccNbProcedures Int?    @map("bodacc_nb_procedures") @db.SmallInt

  // --- Flags techniques (filtres par défaut !) ---
  isRegistrar         Boolean? @map("is_registrar")
  caSuspect           Boolean? @map("ca_suspect")
  isAutoEntrepreneur  Boolean? @map("is_auto_entrepreneur")
  wasInStagingResults Boolean? @map("was_in_staging_results")

  // --- Relations (metier tables, FK on siren) ---
  outreaches       Outreach[]
  callLogs         CallLog[]
  followups        Followup[]
  claudeActivities ClaudeActivity[]
  // Indexes are created by open-data-hub/migration_pg_entreprises.sql
  // (23 indexes including 3 critical composites for segment queries).

  @@map("entreprises")
}

// ============================================================================
// OPERATIONAL TABLES — Referenced by SIREN
// ============================================================================

model Outreach {
  siren         String
  tenantId      String  @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  workspaceId   String? @map("workspace_id") @db.Uuid
  userId        String? @map("user_id") @db.Uuid
  status        String  @default("a_contacter")
  contactedDate String? @map("contacted_date")
  contactMethod String? @map("contact_method")
  notes         String?
  qualification Float?
  lastVisited   String? @map("last_visited")
  updatedAt     String? @map("updated_at")
  position      Int     @default(0)

  // Pipeline commercial (2026-04-15: acte colonnes raw utilisees par le code)
  pipelineStage    String?   @map("pipeline_stage")
  deadline         DateTime? @db.Timestamptz
  interestPct      Int?      @map("interest_pct") @db.SmallInt
  sitePrice        Decimal?  @map("site_price") @db.Decimal(10, 2)
  acomptePct       Int?      @map("acompte_pct") @db.SmallInt
  acompteAmount    Decimal?  @map("acompte_amount") @db.Decimal(10, 2)
  monthlyRecurring Decimal?  @map("monthly_recurring") @db.Decimal(10, 2)
  annualDeal       Boolean?  @default(false) @map("annual_deal")
  estimatedValue   Decimal?  @map("estimated_value") @db.Decimal(10, 2)

  entreprise Entreprise @relation(fields: [siren], references: [siren])

  @@id([siren, tenantId])
  @@index([tenantId, workspaceId])
  @@index([tenantId, userId])
  @@index([tenantId, pipelineStage, deadline])
  @@map("outreach")
}

// Pipeline transitions — historique des changements de stage par prospect.
// Alimente la timeline 360° (fiche historique prospect). Insert hook côté
// src/lib/queries/pipeline.ts à chaque mutation de pipeline_stage.
// Pas de FK vers outreach : outreach a une PK composite (siren, tenant_id)
// et on garde l'historique même si la row outreach est archivée.
model PipelineTransition {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siren       String   @db.VarChar(9)
  tenantId    String   @map("tenant_id") @db.Uuid
  workspaceId String?  @map("workspace_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  fromStage   String?  @map("from_stage") @db.VarChar(64)
  toStage     String   @map("to_stage") @db.VarChar(64)
  occurredAt  DateTime @default(now()) @map("occurred_at") @db.Timestamptz

  @@index([siren, tenantId, occurredAt(sort: Desc)], map: "pipeline_transitions_siren_tenant_occurred_at_idx")
  @@index([tenantId, occurredAt(sort: Desc)], map: "pipeline_transitions_tenant_occurred_at_idx")
  @@index([workspaceId, occurredAt(sort: Desc)], map: "pipeline_transitions_workspace_occurred_at_idx")
  @@map("pipeline_transitions")
}

model ClaudeActivity {
  id           Int     @id @default(autoincrement())
  tenantId     String? @map("tenant_id") @db.Uuid
  workspaceId  String? @map("workspace_id") @db.Uuid
  userId       String? @map("user_id") @db.Uuid
  siren        String
  activityType String  @map("activity_type")
  title        String?
  content      String
  metadata     String?
  createdAt    String  @default(dbgenerated("NOW()")) @map("created_at")

  entreprise Entreprise @relation(fields: [siren], references: [siren])

  @@index([tenantId])
  @@index([tenantId, workspaceId])
  @@index([tenantId, userId])
  @@index([siren])
  @@index([activityType])
  @@index([createdAt(sort: Desc)])
  @@map("claude_activity")
}

model Followup {
  id          Int     @id @default(autoincrement())
  tenantId    String? @map("tenant_id") @db.Uuid
  workspaceId String? @map("workspace_id") @db.Uuid
  siren       String
  scheduledAt String  @map("scheduled_at")
  status      String  @default("pending")
  note        String?
  createdAt   String? @default(dbgenerated("NOW()")) @map("created_at")

  entreprise Entreprise @relation(fields: [siren], references: [siren])

  @@index([tenantId])
  @@index([tenantId, workspaceId])
  @@index([siren])
  @@index([status])
  @@index([scheduledAt])
  @@map("followups")
}

model CallLog {
  id                  Int     @id @default(autoincrement())
  tenantId            String? @map("tenant_id") @db.Uuid
  workspaceId         String? @map("workspace_id") @db.Uuid
  userId              String? @map("user_id") @db.Uuid
  direction           String
  provider            String
  fromNumber          String? @map("from_number")
  toNumber            String? @map("to_number")
  siren               String?
  status              String  @default("initiated")
  startedAt           String  @map("started_at")
  endedAt             String? @map("ended_at")
  durationSeconds     Int?    @map("duration_seconds")
  recordingPath       String? @map("recording_path")
  notes               String?
  telnyxCallControlId String? @map("telnyx_call_control_id")

  entreprise Entreprise? @relation(fields: [siren], references: [siren])

  @@index([tenantId])
  @@index([tenantId, workspaceId])
  @@index([tenantId, userId])
  @@index([siren])
  @@index([startedAt(sort: Desc)])
  @@map("call_log")
}

model LeadSegment {
  siren    String
  segment  String  @default("audit")
  tenantId String  @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  addedAt  String  @map("added_at")
  notes    String?

  @@id([siren, segment, tenantId])
  @@map("lead_segments")
}

model PipelineConfig {
  key      String
  tenantId String @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  value    String

  @@id([key, tenantId])
  @@map("pipeline_config")
}

// ============================================================================
// WORKSPACES — Sous-découpage d'un tenant pour cloisonner les commerciaux
// ============================================================================

model Workspace {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  name          String
  slug          String
  // LEGACY — cap de plan jamais branché (1 ref read-only dans admin/kpi).
  // Conservé tel quel (le drop = migration destructive). Le quota refill
  // vit désormais dans leadsCredited/leadsConsumed ci-dessous.
  leadsLimit    Int?      @map("leads_limit")
  // Quota refill leads (ticket refill 1/3, CONTRAT-BILLING §8.4).
  //   solde = leadsCredited - leadsConsumed
  // - leadsCredited : cumul des crédits (achats Stripe one-shot + welcome).
  //   Incrémenté SEULEMENT par POST /api/tenants/{id}/credit-leads.
  // - leadsConsumed : cumul des leads consommés (1 fiche entreprise débloquée).
  //   Incrémenté par la consultation d'une fiche, idempotent par (ws, siren).
  leadsCredited Int       @default(0) @map("leads_credited")
  leadsConsumed Int       @default(0) @map("leads_consumed")
  createdBy     String?   @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  // SaaS standard — soft delete (P1.1). Purge définitive cron 30j (P1.6).
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  // Contrat Hub §5.6 + §6.2 — Bearer api_key tenant pour generateMagicLink.
  // 1 api_key = 1 workspace (scoping strict). Hash sha256 hex (64 chars), la
  // clé en clair n'est jamais persistée — retournée au Hub une seule fois au
  // provision puis stockée côté Hub dans hub_app.tenants.prospectionApiKey.
  apiKeyHash      String?   @unique @map("api_key_hash")
  apiKeyCreatedAt DateTime? @map("api_key_created_at") @db.Timestamptz

  // Préférences workspace — switch mode agence + onboarding (ticket
  // 2026-05-22 switch-mode-agence-et-onboarding).
  //
  // displayMode : "generic" (DÉFAUT, tri par CA/effectif/prospect_score)
  //             | "agency"  (tri par dette technique — niche agence web)
  // Pas un filtre : les mêmes leads visibles dans les 2 modes, seul l'ORDER BY change.
  //
  // defaultGeoFilters / defaultSectorFilters : choix de l'onboarding,
  // pré-remplissent les sidebars existantes — modifiables à tout moment.
  // JSON arbitraire {departements: ["69", "42"], secteurs: ["BTP", "..."]}
  //
  // onboardingCompletedAt : NULL = onboarding pas fait, l'overlay
  // /components/layout/onboarding.tsx s'affiche au login. Datetime = fait.
  displayMode           String    @default("generic") @map("display_mode")
  defaultGeoFilters     Json?     @map("default_geo_filters")
  defaultSectorFilters  Json?     @map("default_sector_filters")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at") @db.Timestamptz

  members          WorkspaceMember[]
  leadCreditEvents LeadCreditEvent[]
  leadConsumptions LeadConsumption[]
  pipelineStages   WorkspacePipelineStage[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("workspaces")
}

// ============================================================================
// PIPELINE STAGES CUSTOM PAR WORKSPACE
// (ticket 2026-05-23-pipeline-stages-customisables-par-workspace.md)
// ============================================================================
//
// Avant : 8 stages canoniques hardcodés dans src/lib/outreach/status.ts +
// src/lib/types.ts:PIPELINE_STAGES. Le kanban /pipeline et le sélecteur de
// la lead-sheet rendaient ces 8 colonnes en dur — impossible à adapter
// par tenant (les agences B2B ont leur propre workflow).
//
// Après : chaque workspace possède sa propre liste de stages. Au seed de
// la migration 0020, on copie les 8 canoniques pour chaque workspace
// existant — comportement strictement identique pour les clients en place.
// Les admins peuvent ensuite éditer via l'UI /settings/pipeline.
//
// La colonne `outreach.pipeline_stage` reste un `String?` libre — le slug
// d'un stage custom y est écrit tel quel, le kanban groupe par cette
// valeur. Pas de FK SQL stricte pour ne pas orphaniser un lead quand un
// stage est soft-deleted (l'API DELETE refuse le soft-delete s'il reste
// des leads dessus).
model WorkspacePipelineStage {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Slug technique stable (utilisé dans outreach.pipeline_stage). Lowercase
  // snake_case. Unique par workspace. 64 chars — assez large pour des
  // libellés métier verticaux.
  slug        String   @db.VarChar(64)

  // Label affiché à l'utilisateur. Edit live possible sans casser la DB
  // (le slug reste figé même quand le label change).
  label       String   @db.VarChar(80)

  // Ordre d'affichage du kanban (gauche → droite). Les API reorder font un
  // bulk update transactionnel pour éviter les races.
  position    Int      @default(0)

  // Token couleur du badge UI. Token Tailwind ("bg-emerald-500") ou hex.
  // NULL = couleur par défaut (slate).
  color       String?  @db.VarChar(32)

  // Stage terminal : sort le lead du funnel actif (badge différent, exclu
  // des stats "pipeline en cours"). Ex: "client", "perdu".
  isTerminal  Boolean  @default(false) @map("is_terminal")

  // Stage caché du board principal (mais reste filtrable côté historique).
  // Ex: "archive", "spam".
  isHidden    Boolean  @default(false) @map("is_hidden")

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  // Soft-delete : on garde la row pour ne pas orphaniser un lead dont le
  // pipeline_stage pointait dessus. Le code masque les rows where deletedAt
  // IS NOT NULL.
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  @@unique([workspaceId, slug])
  @@index([workspaceId, position])
  @@index([workspaceId, deletedAt])
  @@map("workspace_pipeline_stages")
}

// ============================================================================
// REFILL LEADS — quota + historique (ticket refill 1/3, CONTRAT-BILLING §8.4)
// ============================================================================

// Registre append-only de chaque crédit de leads appliqué à un workspace.
// Double rôle :
//  1. Idempotence — `idempotencyKey @unique` : un signal Hub rejoué (retry
//     Stripe, replay) ne crédite qu'une fois. Même garde que PlanHistory.
//  2. Audit / compta — montant, source, Stripe payment id, date : tout
//     l'historique des achats reste traçable pour le support et la compta.
model LeadCreditEvent {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  quantity        Int
  // 'purchase' (Stripe Checkout one-shot) | 'welcome' (leads offerts).
  source          String
  idempotencyKey  String   @unique @map("idempotency_key")
  stripePaymentId String?  @map("stripe_payment_id")
  contractVersion String?  @map("contract_version")
  // Palier de plan (freemium|pro|business) pour un crédit welcome. NULL pour
  // un crédit 'purchase' (un achat n'a pas de palier). L'index partiel
  // unique ci-dessous garantit l'invariant "welcome offert 1× par palier".
  welcomePlan     String?  @map("welcome_plan")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, welcomePlan], name: "welcome_plan_unique")
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([tenantId])
  @@map("lead_credit_events")
}

// Une ligne = une fiche entreprise consommée par un workspace. La clé
// composite (workspaceId, siren) rend le décompte idempotent : reconsulter
// la même fiche ne recrée pas de ligne → le client ne paie jamais 2× la
// même boîte.
model LeadConsumption {
  workspaceId String   @map("workspace_id") @db.Uuid
  siren       String
  tenantId    String   @map("tenant_id") @db.Uuid
  consumedAt  DateTime @default(now()) @map("consumed_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([workspaceId, siren])
  @@index([tenantId])
  @@map("lead_consumption")
}

model WorkspaceMember {
  workspaceId     String    @map("workspace_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  // Roles: "owner" | "admin" | "member" | "viewer" (voir src/lib/auth/roles.ts)
  // Legacy values "admin" / "member" existent déjà, compat OK.
  role            String    @default("member")
  visibilityScope String    @default("all") @map("visibility_scope") // "all" | "own"
  joinedAt        DateTime  @default(now()) @map("joined_at") @db.Timestamptz
  // SaaS standard — soft delete (P1.1)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  // CONTRAT-HUB §5.21 — freeze cross-app. Si non NULL, le user est en mode
  // dégradé paywall sur ce workspace (obfuscation sensitive fields + 402 sur
  // écritures). Levé via /api/tenants/{id}/unfreeze-members.
  frozenAt        DateTime? @map("frozen_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, deletedAt])
  @@index([frozenAt])
  @@map("workspace_members")
}

// ============================================================================
// AUDIT LOG — SaaS standard (docs/saas-standards.md §7)
// ============================================================================
// Table immutable, read-only, rétention minimum 365 jours.
// Pas de migration encore jouée — P1.7 main agent only. Le helper src/lib/audit.ts
// tolère l'absence de la table (warn + skip) en attendant.

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String?  @map("tenant_id") @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  actorType  String   @map("actor_type") // 'user' | 'hub' | 'stripe' | 'system'
  action     String // 'workspace.deleted', 'plan.changed', ...
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([actorId])
  @@index([action])
  @@map("audit_log")
}

/// Client-side JS errors captured by ClientErrorBoundary (window.onerror +
/// unhandledrejection). Persisted to make intermittent prod bugs queryable.
/// Cf. todo/2026-05-23-persist-client-errors-db.md.
///
/// Dedupe model : one row per (dedupeKey, occurredHour). `dedupeKey` = sha1
/// of (message + filename + lineno) truncated to 16 chars. `occurredHour`
/// = truncated to the hour. The combined unique index lets `/api/errors`
/// upsert + increment `count` instead of growing one row per occurrence,
/// keeping the table bounded even in a crash loop.
///
/// PII guardrails (enforced by /api/errors route, NOT the schema) :
///   - message truncated to 1000 chars
///   - stack truncated to 2000 chars
///   - userAgent truncated to 200 chars
model ClientError {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String?  @map("tenant_id") @db.Uuid
  workspaceId  String?  @map("workspace_id") @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  message      String   @db.Text
  stack        String?  @db.Text
  url          String?  @db.Text
  userAgent    String?  @map("user_agent")
  dedupeKey    String   @map("dedupe_key")
  occurredHour DateTime @map("occurred_hour") @db.Timestamptz
  occurredAt   DateTime @default(now()) @map("occurred_at") @db.Timestamptz
  lastSeenAt   DateTime @default(now()) @map("last_seen_at") @db.Timestamptz
  count        Int      @default(1)

  @@unique([dedupeKey, occurredHour], map: "client_errors_dedupe_hour_key")
  @@index([occurredAt(sort: Desc)])
  @@index([tenantId, occurredAt(sort: Desc)])
  @@map("client_errors")
}

model MagicLink {
  token       String    @id
  email       String
  tenantId    String    @map("tenant_id") @db.Uuid
  workspaceId String?   @map("workspace_id") @db.Uuid
  role        String    @default("member")
  invitedBy   String?   @map("invited_by") @db.Uuid
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  usedAt      DateTime? @map("used_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId])
  @@index([email])
  @@map("magic_links")
}

// Invitation to join a tenant/workspace (persistent, revocable, role-bearing).
// See scripts/2026-04-05_add-invitations-table.sql for the SQL migration.
model Invitation {
  id          Int       @id @default(autoincrement())
  email       String
  invitedBy   String    @map("invited_by") @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  workspaceId String?   @map("workspace_id") @db.Uuid
  role        String    @default("member") // "admin" | "member"
  token       String    @unique
  expiresAt   DateTime  @default(dbgenerated("(now() + interval '7 days')")) @map("expires_at") @db.Timestamptz
  acceptedAt  DateTime? @map("accepted_at") @db.Timestamptz
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId])
  @@index([token])
  @@index([email])
  @@map("invitations")
}

// ============================================================================
// PUSH SUBSCRIPTIONS — Web Push API (PWA notifications)
// ============================================================================
// Stores browser push endpoints for sending notifications (rappels pipeline,
// demos, nouveaux leads). VAPID keys shared with Analytics app.
// Cleanup: expired endpoints (410 Gone) are deleted on send failure.

model PushSubscription {
  id        Int      @id @default(autoincrement())
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Device metadata (for debugging / segmentation)
  userAgent String? @map("user_agent") @db.Text
  platform  String? // "ios" | "android" | "desktop"

  @@index([tenantId])
  @@index([userId])
  @@map("push_subscriptions")
}

// ============================================================================
// APPOINTMENTS — RDV dedies par tenant (source de verite calendrier + push)
// ============================================================================
// Ajoute 2026-04-15. Remplace progressivement outreach.deadline pour le
// tracking des RDV. Le cron check-reminders scanne les deux pendant la
// transition. Voir scripts/2026-04-15_appointments-and-prefs.sql.

model Appointment {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  workspaceId String? @map("workspace_id") @db.Uuid
  userId      String? @map("user_id") @db.Uuid
  siren       String

  startAt  DateTime @map("start_at") @db.Timestamptz
  endAt    DateTime @map("end_at") @db.Timestamptz
  title    String
  location String?
  notes    String?

  // scheduled | done | cancelled | rescheduled
  status String @default("scheduled")

  // URL Google Calendar prerempli (fallback, pas OAuth)
  googleEventUrl String? @map("google_event_url")
  googleEventId  String? @map("google_event_id")

  // Dedup cron push
  notifiedAt DateTime? @map("notified_at") @db.Timestamptz

  // Lien optionnel avec le stage pipeline a l'origine du RDV
  sourceStage String? @map("source_stage")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([tenantId, startAt])
  @@index([tenantId, userId, startAt])
  @@index([siren])
  @@map("appointments")
}

// ============================================================================
// NOTIFICATION PREFERENCES — Per-user toggles pour les push
// ============================================================================

model NotificationPreferences {
  userId                String  @id @map("user_id") @db.Uuid
  tenantId              String  @map("tenant_id") @db.Uuid
  reminderPush          Boolean @default(true) @map("reminder_push")
  reminderMinutesBefore Int     @default(30) @map("reminder_minutes_before") @db.SmallInt
  dailyDigest           Boolean @default(false) @map("daily_digest")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([tenantId])
  @@map("notification_preferences")
}

// ============================================================================
// AUTH.JS v5 — Migration Supabase Auth → Auth.js (2026-05-06)
// Tables locales pour rendre Prospection autonome (plus de dépendance Supabase).
// Pattern copié depuis hub/prisma/schema.prisma (P1.4 hub-auth-builder).
// UUIDs préservés depuis auth.users.id Supabase (compat WorkspaceMember.userId).
// ============================================================================

model User {
  // UUID préservé depuis auth.users.id Supabase pour compat FK existantes.
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified") @db.Timestamptz
  image         String?

  // 2FA email opt-in (cohérent avec Hub)
  mfaEnabled Boolean @default(false) @map("mfa_enabled")

  // Legacy bridge — pour audit / debug. À terme on peut retirer cette colonne
  // (les UUIDs sont identiques à auth.users.id donc redondant) mais on garde
  // pendant la phase de migration pour traçabilité.
  supabaseUserId String? @unique @map("supabase_user_id") @db.Uuid

  // Identité Hub (CONTRAT-HUB v1.5 §3.7). Nullable + backfillé au premier
  // contact Hub (provision, attach-owner, attach-member). Source de vérité
  // humaine côté Hub, PK locale `id` reste inchangée.
  hubUserId String? @unique @map("hub_user_id") @db.Uuid

  accounts Account[]
  sessions Session[]
  mfaCodes MfaCode[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Soft delete (saas-standards §1.6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@index([deletedAt])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String? // pour provider=credentials, contient le bcrypt hash
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model MfaCode {
  id         String    @id @default(cuid())
  userId     String    @map("user_id") @db.Uuid
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("mfa_codes")
}

// ============================================================================
// TENANT — Migré depuis Supabase public.tenants
// Source de vérité de l'état SaaS d'un client (plan, status, integrations
// twenty/notifuse). Auparavant dans Supabase, désormais local à Prospection.
// ============================================================================

enum TenantStatus {
  pending
  active
  suspended
  deleted

  @@map("tenant_status")
}

model Tenant {
  id     String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // user_id = owner (l'utilisateur qui a signé). FK vers User mais le UUID est
  // identique à l'ancien auth.users.id, donc préservé.
  userId String       @map("user_id") @db.Uuid
  name   String
  slug   String       @unique
  status TenantStatus @default(pending)

  // Intégrations Twenty CRM
  twentyWorkspaceId         String?   @map("twenty_workspace_id") @db.Uuid
  twentySubdomain           String?   @map("twenty_subdomain")
  twentyApiKey              String?   @map("twenty_api_key")
  twentyUserEmail           String?   @map("twenty_user_email")
  twentyUserPassword        String?   @map("twenty_user_password")
  twentyLoginToken          String?   @map("twenty_login_token")
  twentyLoginTokenCreatedAt DateTime? @map("twenty_login_token_created_at") @db.Timestamptz

  // Autologin SSO Veridian (couche 1 — token one-shot Hub→Prospection).
  // Le token est généré par POST /api/tenants/provision (HMAC Hub), stocké
  // ici en clair (random 32 bytes hex, validité 24h, one-shot), et consommé
  // par GET /api/auth/token?t=<token> qui crée une session Auth.js locale.
  // Avant 2026-05-20, cette colonne était lue depuis Supabase tenants
  // legacy — migration vers DB locale Prosp pour virer la dépendance Supabase.
  prospectionLoginToken          String?   @map("prospection_login_token")
  prospectionLoginTokenCreatedAt DateTime? @map("prospection_login_token_created_at") @db.Timestamptz
  prospectionLoginTokenUsedAt    DateTime? @map("prospection_login_token_used_at") @db.Timestamptz

  // Intégrations Notifuse
  notifuseWorkspaceSlug    String?   @map("notifuse_workspace_slug")
  notifuseApiKey           String?   @map("notifuse_api_key")
  notifuseUserEmail        String?   @map("notifuse_user_email")
  notifuseInvitationSentAt DateTime? @map("notifuse_invitation_sent_at") @db.Timestamptz

  metadata Json?

  // Plan SaaS — source de vérité pour le pilotage Hub (contrat §5.2).
  // Valeurs possibles : freemium | pro | enterprise | starter |
  // lifetime_site_vitrine | lifetime_partner | internal.
  plan       String? @default("freemium")
  // Source de la dernière mise à jour de plan — bloque le downgrade Stripe
  // sur lifetime_* / internal (cf §3.3 immunité plan_source).
  // Valeurs : stripe | manual | lifetime_site_vitrine | lifetime_partner | internal.
  planSource String? @default("stripe") @map("plan_source")

  provisionedAt  DateTime? @map("provisioned_at") @db.Timestamptz
  lastActivityAt DateTime? @map("last_activity_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Lifecycle v1.1 — machine à états contrat §5.7.
  //
  // Transitions légales :
  //   active ⇄ suspended → soft_deleted → purge_eligible → purged (humain)
  //   soft_deleted → restore vers suspended
  //   soft_deleted + touch → repousse purge_eligible_at
  //
  // Colonnes :
  //   deletedAt        : NOW() au soft-delete, NULL au restore
  //   purgeEligibleAt  : NOW() + SOFT_DELETE_GRACE_DAYS (90j default)
  //   lastTouchedAt    : NOW() à chaque tenant.touched (throttle 24h)
  //   purgedAt         : NOW() au purge irréversible (audit GDPR)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  purgeEligibleAt DateTime? @map("purge_eligible_at") @db.Timestamptz
  lastTouchedAt   DateTime? @map("last_touched_at") @db.Timestamptz
  purgedAt        DateTime? @map("purged_at") @db.Timestamptz

  planHistory PlanHistory[]
  mailConfig  TenantMailConfig?

  @@index([userId])
  @@index([status])
  @@index([deletedAt])
  @@index([purgeEligibleAt])
  @@map("tenants")
}

/// Audit trail des changements de plan (contrat §5.2).
/// Rétention minimale : 50 dernières lignes par tenant.
///
/// `idempotencyKey` : clé de dédup du payload `update-plan` v2
/// (CONTRAT-BILLING.md §3.4.3). Index UNIQUE partiel — un replay du même
/// key viole la contrainte, le handler renvoie alors un 200 no-op. Nullable :
/// les lignes pré-v2 n'ont pas de clé.
model PlanHistory {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  plan           String
  planSource     String   @map("plan_source")
  previousPlan   String?  @map("previous_plan")
  reason         String?
  idempotencyKey String?  @unique @map("idempotency_key")
  changedAt      DateTime @default(now()) @map("changed_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, changedAt(sort: Desc)])
  @@map("veridian_plan_history")
}

/// Configuration SMTP par tenant (mail v1 — envoi sortant BYO commercial).
/// Cf migration 0022_add_mail_config_and_lead_emails. Mot de passe chiffré
/// AES-256-GCM via AUTH_SECRET (lib/crypto/encrypt-password.ts) — JAMAIS
/// stocké en clair, JAMAIS retourné par les routes API au client.
model TenantMailConfig {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @unique @map("tenant_id") @db.Uuid
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  smtpHost         String?  @map("smtp_host") @db.VarChar(255)
  smtpPort         Int?     @map("smtp_port")
  smtpUsername     String?  @map("smtp_username") @db.VarChar(320)
  /// Format : "<iv_b64>:<tag_b64>:<ciphertext_b64>" — voir encrypt-password.ts.
  smtpPasswordEnc  String?  @map("smtp_password_enc")
  smtpTls          Boolean  @default(true) @map("smtp_tls")
  smtpFromEmail    String?  @map("smtp_from_email") @db.VarChar(320)
  smtpFromName     String?  @map("smtp_from_name") @db.VarChar(120)

  lastTestAt       DateTime? @map("last_test_at") @db.Timestamptz
  lastTestStatus   String?   @map("last_test_status") @db.VarChar(32)
  lastTestError    String?   @map("last_test_error")

  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("tenant_mail_config")
}

/// Trace mail envoyé/reçu par prospect — alimente la timeline 360°.
/// v1 = "outgoing" uniquement (SMTP send). v2 IMAP ajoutera "incoming".
/// Pas de FK vers Outreach (même raisonnement que pipeline_transitions :
/// PK composite outreach + archives possibles → on stocke siren + tenant_id).
model LeadEmail {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  workspaceId   String?  @map("workspace_id") @db.Uuid
  userId        String?  @map("user_id") @db.Uuid

  siren         String?  @db.VarChar(9)
  /// "outgoing" | "incoming"
  direction     String   @default("outgoing") @db.VarChar(16)

  messageId     String   @unique @map("message_id") @db.VarChar(255)
  inReplyTo     String?  @map("in_reply_to") @db.VarChar(255)
  references    String?

  fromEmail     String   @map("from_email") @db.VarChar(320)
  fromName      String?  @map("from_name") @db.VarChar(120)
  toEmails      String[] @default([]) @map("to_emails")
  ccEmails      String[] @default([]) @map("cc_emails")
  subject       String?  @db.VarChar(500)
  bodyText      String?  @map("body_text")
  bodyHtml      String?  @map("body_html")

  templateSlug  String?  @map("template_slug") @db.VarChar(64)

  /// "queued" | "sent" | "failed"
  sentStatus    String   @default("queued") @map("sent_status") @db.VarChar(16)
  sentError     String?  @map("sent_error")
  sentAt        DateTime? @map("sent_at") @db.Timestamptz

  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([siren, tenantId, sentAt(sort: Desc)])
  @@index([tenantId, sentAt(sort: Desc)])
  @@index([tenantId, sentStatus])
  @@map("lead_emails")
}

/// Pattern transactional outbox — webhooks Prospection → Hub durables.
///
/// Cf ticket 2026-05-23-emit-webhook-events-niveau2-sync-followup-outbox.md
/// et migration 0023. Au lieu d'émettre fire-and-forget depuis chaque route
/// mutante (risque de perte si crash entre commit DB et fetch sortant), on
/// INSERT une row dans `webhook_outbox` dans la MÊME transaction Prisma. Un
/// worker cron (POST /api/cron/process-outbox) consomme ensuite les rows
/// avec retry exponentiel.
///
/// `status` (text + CHECK côté SQL, string ici pour rester additif) :
///   - `pending`       — enqueued, jamais essayé
///   - `sending`       — locké par un worker via SELECT FOR UPDATE
///   - `sent`          — Hub a répondu 200 (dédup côté Hub via idempotency_key)
///   - `failed_retry`  — fetch a échoué, en attente du prochain retry
///   - `dead`          — > MAX_ATTEMPTS échecs consécutifs, sortie de la file
///
/// `nextRetryAt` : backoff exponentiel (1s, 2s, 4s, 8s, …, cap 1h).
/// `idempotencyKey` : UUID injecté dans le payload Hub (header §7.1 v1.4),
/// UNIQUE côté outbox pour rejeter à l'INSERT un replay.
///
/// Pas de FK vers `tenants` exprès : un event peut survivre au purge du
/// tenant (cas legit : `tenant.purged` lui-même), et inversement le worker
/// doit pouvoir nettoyer des events orphelins sans cascade.
model WebhookOutbox {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType      String    @map("event_type") @db.VarChar(64)
  tenantId       String    @map("tenant_id") @db.Uuid
  payload        Json
  idempotencyKey String    @unique @map("idempotency_key") @db.Uuid
  status         String    @default("pending") @db.VarChar(16)
  attempts       Int       @default(0)
  nextRetryAt    DateTime  @default(now()) @map("next_retry_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  sentAt         DateTime? @map("sent_at") @db.Timestamptz
  lastError      String?   @map("last_error")

  @@index([status, nextRetryAt])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([status])
  @@map("webhook_outbox")
}
